{
  "schemaVersion": 1,
  "id": "aspectalchemy",
  "version": "${version}",
  "name": "Aspect Alchemy",
  "description": "Brew unique potions by combining alchemical aspects of Minecraft items!",
  "authors": [
    "NezerX"
  ],
  "contact": {
    "homepage": "https://github.com/NezerX/Aspect-Alchemy",
    "sources": "https://github.com/NezerX/Aspect-Alchemy"
  },
  "license": "MIT",
  "icon": "assets/aspectalchemy/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "nezerx.aspectalchemy.fabric.AspectAlchemyFabric"
    ],
    "client": [
      "nezerx.aspectalchemy.fabric.client.AspectAlchemyFabricClient"
    ],
    "jade": [
      "nezerx.aspectalchemy.compat.jade.AspectAlchemyJadePlugin"
    ]
  },
  "mixins": [
    "aspectalchemy.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "architectury": ">=${architectury_api_version}",
    "fabric-api": "*"
  },
  "suggests": {
    "jade": "*",
    "patchouli": "*"
  }
}
